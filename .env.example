# PostgreSQL with pgvector extension
# e.g. postgresql://user:password@localhost:5432/rag
DATABASE_URL=

# Voyage AI — code-optimised embeddings (https://www.voyageai.com)
VOYAGE_API_KEY=

# Anthropic — optional, only required for scripts/ask.py (https://console.anthropic.com)
# ANTHROPIC_API_KEY=

# GitHub — optional; raises API rate limit from 60 to 5000 req/hr; required for private repos
# GITHUB_TOKEN=

# ── MCP HTTP authentication (required when running --transport http) ───────────
# Restrict access to a Google Workspace domain (e.g. "bes.au")
GOOGLE_ALLOWED_DOMAIN=

# Or restrict to specific emails (comma-separated)
# GOOGLE_ALLOWED_EMAILS=alice@example.com,bob@example.com

# ── After setting the above, index a repository: ──────────────────────────────
#   uv run python scripts/ingest.py --repo https://github.com/beyondessential/tupaia --namespace tupaia
# Or use an existing local checkout:
#   uv run python scripts/ingest.py /path/to/tupaia --namespace tupaia
